# Continuous KYC Autonomous Auditor -- example environment file
#
# Copy this to `.env` in the `backend/` directory if you need to override a
# default. Nothing here is required to run the app locally -- every setting
# has a safe, working default computed relative to this file's location
# (see app/core/config.py). Never commit a real `.env` with secrets.

APP_NAME="Continuous KYC Autonomous Auditor"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# SQLite by default. Leave unset to use ./data/continuous_kyc.db under backend/.
# DATABASE_URL=sqlite:///./data/continuous_kyc.db

# Leave unset to auto-resolve to <project_root>/data (the Phase 0 dataset directory).
# RAW_DATA_DIR=../data
# PROCESSED_DATA_DIR=../data/processed

LOG_LEVEL=INFO

# --- Future external provider integrations (contracts + plumbing only) ---
# These three providers make ZERO network calls and honestly report
# NOT_CONFIGURED -- they are placeholders, not integrations. Leave unset.
# Never commit real values here or in a real `.env`.
# NEWS_API_KEY=
# NEWS_API_BASE_URL=
# SANCTIONS_API_KEY=
# SANCTIONS_API_BASE_URL=
# CORPORATE_REGISTRY_API_KEY=
# CORPORATE_REGISTRY_API_BASE_URL=

# --- Phase 5: the Investigation Agent's LLM provider (REAL integration) ---
# Unlike the three above, these genuinely call an API when configured.
#
# With no key set, the agent makes no call and every investigation is recorded
# as FAILED with the reason. It never returns a fabricated or placeholder
# report -- that behaviour is the default, and it is deliberate.
#
# NEVER COMMIT A REAL KEY. `.env` is git-ignored; only this example is tracked.

# Which registered LLMProvider to use (app/providers/llm_registry.py).
# Registered: anthropic | groq
# LLM_PROVIDER=anthropic

# --- Vendor-neutral knobs (honoured by every provider) ---
# LLM_MAX_OUTPUT_TOKENS=8000
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=2

# Sent ONLY by providers whose API accepts sampling parameters.
#   groq      -> sent, and the real value is recorded.
#   anthropic -> IGNORED. Current models reject temperature with HTTP 400, so
#                none is sent and the recorded value is null (ADR-025).
# Default 0.0: least output variance for a compliance report.
# LLM_TEMPERATURE=0.0

# --- Anthropic (LLM_PROVIDER=anthropic) ---
# LLM_API_KEY is read first, then the SDK's conventional ANTHROPIC_API_KEY.
# LLM_API_KEY=
# The model is CONFIGURATION, never a constant in the agent -- hardcoding a
# model id is the same class of mistake as hardcoding a client id.
# LLM_MODEL=claude-opus-4-8
# LLM_BASE_URL=

# --- Groq (LLM_PROVIDER=groq) ---
# GROQ_API_KEY is read first, then the SDK's conventional GROQ_API_KEY env var.
# Get a key at https://console.groq.com/keys
# GROQ_API_KEY=

# Must be a model that supports STRUCTURED OUTPUTS (json_schema). The report
# schema is enforced by constrained decoding, so a model without it cannot be
# used -- the investigation will fail loudly with an actionable message rather
# than return unvalidated prose.
#   Strict mode (GROQ_STRICT_SCHEMA=true):
#     openai/gpt-oss-120b   <- default
#     openai/gpt-oss-20b
#   Best-effort only (set GROQ_STRICT_SCHEMA=false):
#     openai/gpt-oss-safeguard-20b
#     meta-llama/llama-4-scout-17b-16e-instruct
#   See https://console.groq.com/docs/structured-outputs
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_STRICT_SCHEMA=true
# GROQ_BASE_URL=
