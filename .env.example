# Docker Compose environment. Copy to `.env` beside docker-compose.yml.
# NEVER commit a real key. `.env` is git-ignored.

# Which LLM provider the Investigation Agent uses: groq | anthropic
LLM_PROVIDER=groq

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- Anthropic ---
# LLM_API_KEY=
# LLM_MODEL=claude-opus-4-8

# Groq counts input + RESERVED output against its tokens-per-minute limit,
# so this is a TPM setting, not just an output cap. 4000 fits the free tier.
LLM_MAX_OUTPUT_TOKENS=4000
LLM_TEMPERATURE=0.0
